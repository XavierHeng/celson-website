# Cloudflare Pages Cache-Control Headers
# https://developers.cloudflare.com/pages/configuration/headers/

# HTML — short cache (content changes frequently)
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# CSS / JS — long cache with content hash busting
/css/*
  Cache-Control: public, max-age=3600, must-revalidate

/js/*
  Cache-Control: public, max-age=86400, must-revalidate

# Images (WebP) — very long cache
/assets/*.webp
  Cache-Control: public, max-age=31536000, immutable

# Images (JPG fallback) — very long cache
/assets/*.jpg
  Cache-Control: public, max-age=31536000, immutable

# SVG — long cache
/assets/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Root (/) — short cache
/
  Cache-Control: public, max-age=3600, must-revalidate

# PWA — Service Worker (in js/, scope / via Service-Worker-Allowed)
/js/sw.js
  Content-Type: application/javascript; charset=utf-8
  Service-Worker-Allowed: /
  Cache-Control: no-cache

# PWA — Manifest (in assets/)
/assets/manifest.json
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=3600

# PWA — Offline fallback
/offline.html
  Cache-Control: public, max-age=3600, must-revalidate

# PWA — Icons
/assets/pwa/*
  Cache-Control: public, max-age=31536000, immutable

# Security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
